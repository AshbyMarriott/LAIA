# LAIA environment variables
# Copy to .env and adjust for your machine.

# Required: single MVP API key (sent as X-API-Key)
LAIA_API_KEY=dev-api-key-change-me

# Postgres (Compose default shown)
DATABASE_URL=postgresql+asyncpg://laia:laia@postgres:5432/laia

# Ollama — inside Compose use the service name; on Mac point at native Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Selected after Phase 3 model bakeoff
OLLAMA_MODEL=qwen2.5:7b

# Default user timezone (IANA)
LAIA_TIMEZONE=America/Chicago

# Pending clarification/confirmation TTL
CONVERSATION_TTL_MINUTES=15

# Logging
LOG_LEVEL=INFO
